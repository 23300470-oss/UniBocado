# Puerto en el que corre el servidor localmente
PORT=5500

# URL de conexión de base de datos PostgreSQL / Supabase
# Reemplaza con tu cadena de conexión real de Supabase (Database -> Connection String -> URI)
DATABASE_URL=postgresql://postgres.xxx:tu_contraseña@aws-0-us-west-1.pooler.supabase.com:6543/postgres?sslmode=require
